class Solution {
public:
    int majorityElement(vector<int>& nums) {
        int candidate = 0;
        int count = 0;

        for (int num : nums) {
            // If count is 0, we assume the current number is the majority candidate
            if (count == 0) {
                candidate = num;
            }

            // If the current number matches the candidate, increment count
            // Otherwise, decrement count (it "cancels out" a vote)
            count += (num == candidate) ? 1 : -1;
        }

        return candidate;
    }
};
