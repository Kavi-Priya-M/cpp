class Solution {
public:
    int canCompleteCircuit(vector<int>& gas, vector<int>& cost) {
        int total_surplus = 0; // Total gas - Total cost
        int current_surplus = 0; // Gas left in tank for the current trip
        int start_node = 0;

        for (int i = 0; i < gas.size(); i++) {
            int diff = gas[i] - cost[i];
            total_surplus += diff;
            current_surplus += diff;

            
            if (current_surplus < 0) {
                // Reset the trip: try starting from the next station
                start_node = i + 1;
                current_surplus = 0;
            }
        }

            return (total_surplus < 0) ? -1 : start_node;
    }
};
